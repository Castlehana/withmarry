{
  "name": "withmarry",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "our-story:chapters": "node scripts/generate-our-story-chapters.mjs",
    "dev": "node scripts/generate-our-story-chapters.mjs && vite",
    "dev:force": "node scripts/generate-our-story-chapters.mjs && vite --force",
    "build": "node scripts/generate-our-story-chapters.mjs && vite build",
    "preview": "vite preview",
    "pages:dev": "npm run d1:migrate:local && npm run build && wrangler pages dev dist --port 8788",
    "d1:migrate:local": "wrangler d1 migrations apply withmarry-rsvp --local",
    "d1:migrate:remote": "wrangler d1 migrations apply withmarry-rsvp --remote"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "simplex-noise": "^4.0.3",
    "three": "^0.160.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^5.4.11",
    "wrangler": "^4.85.0"
  }
}
